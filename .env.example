# Cloudflare D1 数据库配置
# 数据库名称: user_auth
# 数据表: users

# Cloudflare 账户信息
CF_ACCOUNT_ID=your_cloudflare_account_id_here

# Cloudflare D1 数据库 ID（通过环境变量读取）
CF_D1_DATABASE_ID=your_database_id_here

# Cloudflare API Token（用于数据库操作）
CF_API_TOKEN=your_api_token_here

# JWT 密钥（用于生成和验证 token）
# 建议：使用至少 32 字符的随机字符串
JWT_SECRET=your_jwt_secret_here_at_least_32_characters

# 注意：
# 1. 所有敏感信息请通过 Cloudflare Dashboard 或 wrangler.toml 配置
# 2. DB 绑定别名已配置为 "DB"
# 3. 在代码中通过 env.DB 或 process.env.DB 访问数据库实例